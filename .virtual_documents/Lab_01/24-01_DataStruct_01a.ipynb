# Conversion to binary 
def decToBinary( x ):
    out = Stack('Bits')
    
    while x > 0:
        bit = x % 2
        out.push(bit)
        x = x // 2
    return out


bin = decToBinary(253)
bin.print()
print(bin.get_data()[::-1])





# Conversion to binary 
def decToBinary2( x ):
    out = Queue('Bits')
    
    while x > 0:
        bit = x % 2
        out.push(bit)
        x = x // 2
    return out


bin = decToBinary2(253)
bin.print()
print(bin.get_data()[::-1])


from DataStructures import Stack, Queue

# binary to decimal
def binaryToDecimal( st ):
    out = 0
    potenca = 2**(st.size()-1)
    while not st.empty():
        out += potenca*st.pop()
        potenca = potenca // 2

    return out

bin = decToBinary(122342312)
bin.print()
print(bin.get_data()[::-1])

print(binaryToDecimal(bin))



from DataStructures import Stack, Queue

# binary to decimal
def binaryToDecimal2( st ):
    out = 0
    potenca = 1 #2**(st.size()-1)
    while not st.empty():
        out += potenca*st.dequeue()
        potenca = potenca * 2

    return out

bin = decToBinary2(122342312)
bin.print()
print(bin.get_data()[::-1])

print(binaryToDecimal2(bin))





